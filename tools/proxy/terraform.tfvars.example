# DigitalOcean + Cloudflare API tokens (or export DIGITALOCEAN_TOKEN / CLOUDFLARE_API_TOKEN).
do_token             = "dop_v1_..."
cloudflare_api_token = "..."

# Cloudflare-hosted parent zone. The proxied record is created here.
parent_domain = "semaphoreui.dev"

# Optional: record label under parent_domain (defaults to "proxy-<workspace>").
# subdomain = "proxy"

# Optional droplet overrides.
# size   = "s-1vcpu-1gb"
# region = "fra1"
