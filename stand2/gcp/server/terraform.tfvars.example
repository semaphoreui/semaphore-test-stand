gcp_project          = "your-gcp-project-id"
cloudflare_api_token = "your-cloudflare-api-token" # DNS edit + zone read on parent_domain
ssh_public_key       = "ssh-ed25519 AAAA... you@example.com"
# ssh_user           = "ubuntu"  # optional, default "ubuntu"

# Authenticate with Google Cloud out-of-band before apply:
#   gcloud auth application-default login
# (or set GOOGLE_APPLICATION_CREDENTIALS to a service-account key file)

# Load balancer SSL (Google-managed certificate).
# The sub-zone "<prefix>.<parent_domain>" is created in Google Cloud DNS and must
# be delegated from the parent domain (NS records, added automatically in the
# Cloudflare parent zone). With prefix="semaphore" the LB host becomes
# lb.semaphore.semaphoreui.dev
parent_domain = "semaphoreui.dev"
# lb_subdomain = "lb"   # optional, default "lb"

# Application secrets (override the insecure placeholders below!)
db_password                     = "change-me-postgres"
redis_password                  = "change-me-redis"
semaphore_admin_password        = "change-me-admin"
semaphore_cookie_hash           = "generate-with: head -c32 /dev/urandom | base64"
semaphore_cookie_encryption     = "generate-with: head -c32 /dev/urandom | base64"
semaphore_access_key_encryption = "generate-with: head -c32 /dev/urandom | base64"

# Optional: register runners automatically on first boot.
# runner_registration_token = "..."

# Optional overrides
# region       = "europe-west3"        # us-central1/europe-west1/asia-east1/...
# zone         = "europe-west3-a"      # must be inside region
# machine_type = "e2-small"
