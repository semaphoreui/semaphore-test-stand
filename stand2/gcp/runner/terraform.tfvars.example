gcp_project    = "your-gcp-project-id"
ssh_public_key = "ssh-ed25519 AAAA... you@example.com"
# ssh_user     = "ubuntu"  # optional, default "ubuntu"
prefix         = "semaphore"

# Authenticate with Google Cloud out-of-band before apply:
#   gcloud auth application-default login

# Point runners at the server cluster's load balancer and API.
web_root  = "https://lb.semaphore.semaphoreui.dev"
api_token = "your-semaphore-api-token"

# Each runner picks its own region/zone. A subnet + Cloud NAT is created per
# distinct region, all inside a dedicated runner VPC.
runners = {
  "ci-eu"  = { name = "runner1", region = "europe-west3", zone = "a" }
  "ci-us"  = { name = "runner2", region = "us-central1",  zone = "a" }
  "deploy" = { name = "runner3", region = "asia-east1",   zone = "a" }
}

# Optional overrides
# region            = "europe-west3"     # google provider default only
# zone              = "europe-west3-a"   # google provider default only
# runner_cidr       = "10.20.0.0/16"     # base CIDR; a /24 is carved per region
# machine_type      = "e2-small"
# semaphore_version = "2.18.6-beta1"
