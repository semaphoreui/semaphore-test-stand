gcp_project    = "your-gcp-project-id"
ssh_public_key = "ssh-ed25519 AAAA... you@example.com"
# ssh_user     = "ubuntu"  # optional, default "ubuntu"
prefix         = "semaphore"  # must match the server stack's prefix

# Authenticate with Google Cloud out-of-band before apply:
#   gcloud auth application-default login

# Point runners at the server cluster's load balancer and API.
web_root  = "https://lb.semaphore.semaphoreui.dev"
api_token = "your-semaphore-api-token"

runners = {
  "ci-eu"  = { name = "runner1" }
  "ci-us"  = { name = "runner2" }
  "deploy" = { name = "runner3" }
}

# Optional overrides
# region            = "europe-west3"
# zone              = "europe-west3-a"
# machine_type      = "e2-small"
# semaphore_version = "2.18.6-beta1"
